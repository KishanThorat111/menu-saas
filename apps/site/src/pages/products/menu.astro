---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import CTASection from '../../components/CTASection.astro';

const features = [
  { title: 'Short, brand-safe QR menus', desc: '6-character base32 codes. /m/{code} resolves to a mobile-first menu in milliseconds, with a 60-second in-memory cache.' },
  { title: '15 themes, plan-gated', desc: 'Starter unlocks 4 themes, Standard 8, Pro all 15. Logo, colors, and typography render on the customer page without an extra round trip.' },
  { title: 'UPI Pay, no card processing', desc: 'Direct upi:// deep-link on mobile, signed UPI QR fallback on desktop. KodSpot never touches the funds — your existing UPI ID does.' },
  { title: 'Printable QR cards', desc: 'Five card themes, A6 high-resolution export, optional review and UPI QR on the reverse — generated entirely in-browser.' },
  { title: 'Privacy-safe analytics', desc: 'Daily scans + plan-aware unique visitor counts via hashed visitor identifiers. Soft cap on analytics; the menu itself never goes dark.' },
  { title: 'Lifecycle automation', desc: 'Trial → Active → Grace → Expired transitions run on an hourly cron. Razorpay payments and webhook events activate or schedule plan changes.' }
];

const plans = [
  {
    name: 'Starter',
    price: '₹499',
    period: '/month',
    features: ['4 menu themes', '150 unique visitors / day', '1-day analytics', 'Walnut QR card', 'KodSpot branding']
  },
  {
    name: 'Standard',
    price: '₹999',
    period: '/month',
    highlight: true,
    features: ['8 menu themes', '500 unique visitors / day', '7-day analytics', 'All QR card themes', 'UPI Pay enabled', 'KodSpot branding']
  },
  {
    name: 'Pro',
    price: '₹1,499',
    period: '/month',
    features: ['All 15 themes', 'Unlimited unique visitors', '30-day analytics', 'All QR card themes', 'UPI Pay enabled', 'Branding removed']
  }
];
---
<BaseLayout
  title="KodSpot Menu — QR Menu SaaS"
  description="Multi-tenant QR menu platform for restaurants, cafés and hotels. Themes, UPI Pay, analytics, printable QR cards and Razorpay billing — production today on kodspot.com."
>
  <section class="container-page pt-20 sm:pt-28">
    <span class="chip" data-reveal>Live · kodspot.com</span>
    <h1 class="heading-1 mt-5 max-w-3xl" data-reveal data-reveal-delay="1">
      QR menus that look like a brand, not a PDF.
    </h1>
    <p class="lead mt-5 max-w-2xl" data-reveal data-reveal-delay="2">
      KodSpot Menu is the multi-tenant QR menu SaaS we run on <span class="font-medium">kodspot.com</span>. Restaurants get a 6-character menu code, a themed mobile menu, UPI Pay, printable QR cards and analytics — and we run the platform.
    </p>
    <div class="mt-8 flex flex-wrap gap-3" data-reveal data-reveal-delay="3">
      <a href="/contact" class="btn-accent">Request a trial</a>
      <a href="/admin" class="btn-outline">Owner login</a>
    </div>
  </section>

  <section class="container-page mt-20 sm:mt-28">
    <SectionHeading eyebrow="Capabilities" title="Everything a small restaurant needs, none of the bloat." />
    <div class="mt-12">
      <FeatureGrid features={features} />
    </div>
  </section>

  {/* Pricing */}
  <section class="container-page mt-24 sm:mt-32">
    <SectionHeading eyebrow="Pricing" title="Simple monthly plans. Cancel any time." />
    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {plans.map((plan, i) => (
        <div
          data-reveal
          data-reveal-delay={i + 1}
          class:list={[
            'relative rounded-3xl p-7 border transition-all',
            plan.highlight
              ? 'bg-gradient-to-br from-brand-500 to-brand-700 text-white border-transparent shadow-lift'
              : 'surface-solid hover:border-brand-300 dark:hover:border-brand-600/60'
          ]}
        >
          {plan.highlight && (
            <span class="absolute -top-3 right-6 rounded-full bg-white text-brand-700 text-xs font-semibold px-3 py-1 shadow-soft">Most popular</span>
          )}
          <h3 class="text-lg font-semibold">{plan.name}</h3>
          <p class:list={['mt-2 text-3xl font-display font-semibold', plan.highlight ? 'text-white' : '']}>
            {plan.price}
            <span class:list={['ml-1 text-sm font-normal', plan.highlight ? 'text-white/80' : 'muted']}>{plan.period}</span>
          </p>
          <ul class="mt-5 space-y-2 text-sm">
            {plan.features.map((f) => (
              <li class="flex gap-2">
                <svg class:list={['h-5 w-5 flex-none', plan.highlight ? 'text-white' : 'text-brand-500']} xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <a href="/contact" class:list={['mt-7 w-full', plan.highlight ? 'btn bg-white text-brand-700 hover:bg-ink-100' : 'btn-primary']}>Get started</a>
        </div>
      ))}
    </div>
    <p class="mt-6 text-xs muted text-center">
      All plans include a 14-day free trial with Standard-tier features. No card required.
    </p>
  </section>

  <CTASection
    title="See it on a real restaurant menu."
    body="Send us your restaurant name and city — we’ll publish your QR menu within hours."
    primary={{ label: 'Request a trial', href: '/contact' }}
    secondary={{ label: 'See the architecture', href: '/technology' }}
  />
</BaseLayout>
