---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import CTASection from '../../components/CTASection.astro';
import PageHero from '../../components/PageHero.astro';
import { PRODUCTS } from '../../lib/site';
---
<BaseLayout
  title="Products"
  description="Three production SaaS platforms — Menu, Housekeeping, Electrical — for hospitals, hotels, and restaurants across India."
>
  <PageHero
    eyebrow="Products"
    title="Specialised SaaS for"
    highlight="physical operations."
    lead="Menu for hospitality. Housekeeping for hospitals and hotels. Electrical for facility reliability. All multi-tenant, all production."
  />

  <section class="container-page mt-4 sm:mt-8">
    <div class="grid gap-6 lg:grid-cols-3 lg:auto-rows-fr">
      {PRODUCTS.map((p, i) => <ProductCard product={p} delay={i + 1} />)}
    </div>
  </section>

  <section class="container-page mt-24 sm:mt-32">
    <div class="conic-border surface-solid p-8 sm:p-12 lg:p-16 spotlight">
      <div class="grid gap-10 lg:grid-cols-2 lg:gap-16 items-start">
        <div data-reveal>
          <p class="eyebrow">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
            Foundation
          </p>
          <h2 class="heading-3 mt-4">Same foundation, different surfaces.</h2>
          <p class="mt-5 muted leading-relaxed text-base sm:text-lg">
            Every product runs on the same multi-tenant Fastify + PostgreSQL core, the same audit-log discipline, the same encrypted-PII rules and the same SQL-first AI routing. We build vertical surfaces — but never a vertical stack.
          </p>
        </div>
        <ul class="space-y-4" data-reveal data-reveal-delay="1">
          {[
            'Per-tenant data isolation enforced at the route, query, and cache layer',
            'Soft-delete with scheduled hard purge for DPDPA-aligned data retention',
            'Health-checked, container-isolated services with encrypted DB backups',
            'PWA with offline queues so field workers stay productive without connectivity',
            'Per-organisation AI configuration with token caps and usage logs'
          ].map((it, i) => (
            <li class="flex gap-3 text-sm sm:text-base" data-reveal data-reveal-delay={Math.min(i + 1, 5)}>
              <span class="mt-0.5 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-gradient-to-br from-brand-400 to-brand-600 text-white shadow-ring-brand">
                <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              <span class="text-ink-700 dark:text-ink-300">{it}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
