---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import PageHero from '../components/PageHero.astro';
import { CASE_STUDIES } from '../lib/site';
---
<BaseLayout
  title="Case Studies"
  description="Anonymised case studies from production deployments of KodSpot Housekeeping, Electrical and Menu across hospitals, hotels and restaurants."
>
  <PageHero
    eyebrow="Case Studies"
    title="Production deployments."
    highlight="Real operations."
    lead="Where KodSpot is running today across hospitals, hotels and electrical departments. Names used with permission; engagement specifics framed at a level our clients are comfortable being public about."
  />

  <section class="container-page mt-8 sm:mt-12">
    <div class="grid gap-6 lg:grid-cols-3 lg:auto-rows-fr">
      {CASE_STUDIES.map((cs, i) => (
        <article
          data-reveal
          data-reveal-delay={i + 1}
          data-tilt="5"
          class="group card-glow spotlight surface-solid p-7 sm:p-8 flex flex-col h-full transition-all"
        >
          <div class="flex items-center justify-between gap-3">
            <span class="chip">{cs.industry}</span>
            <span class="font-mono text-[10px] tracking-[0.18em] muted uppercase text-right">{cs.product}</span>
          </div>
          <p class="mt-6 eyebrow">
            <span class="h-1 w-1 rounded-full bg-brand-500"></span>
            {cs.client}
          </p>
          <h3 class="mt-3 font-display text-2xl sm:text-3xl tracking-tight leading-tight">{cs.title}</h3>
          <p class="mt-4 muted leading-relaxed text-sm flex-1">{cs.summary}</p>
          <dl class="mt-7 space-y-3.5 border-t border-ink-200/70 dark:border-ink-800/70 pt-6">
            {cs.metrics.map((m) => (
              <div class="flex items-start justify-between gap-4">
                <dt class="text-xs uppercase tracking-wider muted leading-snug">{m.l}</dt>
                <dd class="font-display text-base font-medium gradient-brand-text whitespace-nowrap">{m.v}</dd>
              </div>
            ))}
          </dl>
        </article>
      ))}
    </div>
  </section>

  <CTASection
    title="Need a reference call?"
    body="We can connect you with a current operator using KodSpot in production, subject to their availability."
  />
</BaseLayout>
