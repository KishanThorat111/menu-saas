---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import Stats from '../components/Stats.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import CTASection from '../components/CTASection.astro';
import Logo from '../components/Logo.astro';
import { PRODUCTS, SITE, CLIENT_LOGOS } from '../lib/site';

const pillars = [
  { title: 'Multi-tenant by design', desc: 'One platform, many organisations. Strict tenant isolation at every database row, route, and cache key.' },
  { title: 'AI with cost discipline', desc: 'SQL-first router with per-tenant token caps. Vertex AI, Gemini, Azure OpenAI — chosen per workload.' },
  { title: 'DPDPA-aligned compliance', desc: 'Soft delete with scheduled purge, encrypted PII, audit logs on every privileged action, IP hashing for analytics.' },
  { title: 'Production-grade delivery', desc: 'Containerised, health-checked, encrypted backups, GitHub Actions CI/CD, PWA with offline queues for field use.' },
  { title: 'Built for India', desc: 'UPI Pay, Razorpay, regional carriers, low-bandwidth mobile flows, vernacular-ready surfaces.' },
  { title: 'Single founder, full stack', desc: 'No hand-offs. The same engineer designs the schema, ships the APIs, hardens the infra and writes this paragraph.' }
];

const marqueeWords = ['Hospitals', 'Hotels', 'Restaurants', 'Manufacturing', 'Education', 'Hospitality', 'Healthcare', 'Field Operations'];
---
<BaseLayout title={SITE.tagline} description={SITE.description}>
  {/* ============ HERO ============ */}
  <section class="relative isolate overflow-hidden">
    {/* Animated mesh gradient backdrop */}
    <div class="absolute inset-0 -z-20 mesh-bg opacity-90 pointer-events-none"></div>
    <div class="absolute inset-0 -z-10 grid-bg opacity-40 pointer-events-none"></div>

    {/* Floating orbs */}
    <div class="orb orb-1 h-[420px] w-[420px] -top-32 -left-24 animate-float-slow" style="animation-delay:-2s"></div>
    <div class="orb orb-2 h-[360px] w-[360px] top-32 right-[-80px] animate-float-slower" style="animation-delay:-6s"></div>
    <div class="orb orb-3 h-[300px] w-[300px] bottom-[-120px] left-1/3 animate-float-slow opacity-40" style="animation-delay:-12s"></div>

    <div class="container-page relative pt-16 sm:pt-24 lg:pt-28 pb-24 sm:pb-32">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        {/* Left: text */}
        <div class="lg:col-span-7">
          <span class="chip backdrop-blur-md" data-reveal>
            <span class="relative flex h-2 w-2">
              <span class="absolute inset-0 rounded-full bg-emerald-500 animate-ping opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
            </span>
            Three SaaS platforms in production · Belagavi, India
          </span>

          <h1 class="heading-1 mt-7 text-balance">
            <span data-split data-text="Operations technology for"></span>
            <span class="block gradient-brand-text italic" data-reveal data-reveal-delay="3">physical businesses.</span>
          </h1>

          <p class="lead mt-7 max-w-2xl" data-reveal data-reveal-delay="4">
            {SITE.description}
          </p>

          <div class="mt-9 flex flex-wrap gap-3" data-reveal data-reveal-delay="5">
            <a href="/products" class="btn-accent magnetic" data-magnetic="0.3">
              Explore products
              <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="/technology" class="btn-outline magnetic" data-magnetic="0.2">See the technology</a>
            <a href={SITE.whatsappUrl} class="btn-ghost magnetic" data-magnetic="0.2" target="_blank" rel="noopener">
              <svg class="h-4 w-4 text-emerald-500" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.81 11.81 0 018.413 3.488 11.824 11.824 0 013.48 8.413c-.003 6.557-5.338 11.892-11.892 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26L3.516 20.9l5.138-1.346zM17.472 14.382c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
              WhatsApp us
            </a>
          </div>

          <dl class="mt-10 grid grid-cols-3 gap-6 max-w-xl" data-reveal data-reveal-delay="6">
            <div>
              <dt class="text-[11px] muted uppercase tracking-[0.2em] font-semibold">Hosting</dt>
              <dd class="mt-1.5 text-sm font-medium">GCP · multi-cloud ready</dd>
            </div>
            <div>
              <dt class="text-[11px] muted uppercase tracking-[0.2em] font-semibold">Stack</dt>
              <dd class="mt-1.5 text-sm font-medium">Fastify · Prisma · Postgres</dd>
            </div>
            <div>
              <dt class="text-[11px] muted uppercase tracking-[0.2em] font-semibold">AI</dt>
              <dd class="mt-1.5 text-sm font-medium">Vertex · Gemini · Azure OpenAI</dd>
            </div>
          </dl>
        </div>

        {/* Right: floating logo orb / product preview card */}
        <div class="lg:col-span-5 relative perspective order-first lg:order-last" data-reveal data-reveal-delay="3">
          <div class="relative mx-auto max-w-[260px] sm:max-w-sm lg:max-w-md" data-tilt="10">
            {/* Floating logo halo */}
            <div class="relative aspect-square">
              <div class="absolute inset-0 rounded-full bg-gradient-to-br from-brand-300/30 via-brand-500/20 to-transparent blur-3xl animate-pulse-soft"></div>
              <div class="absolute inset-6 rounded-full border border-brand-300/30 dark:border-brand-500/20 animate-spin-slow"></div>
              <div class="absolute inset-14 rounded-full border border-brand-300/20 dark:border-brand-500/15 animate-spin-slow" style="animation-direction:reverse;animation-duration:22s"></div>

              {/* The actual logo */}
              <div class="absolute inset-0 flex items-center justify-center">
                <Logo class="h-32 w-32 sm:h-44 sm:w-44 lg:h-56 lg:w-56 drop-shadow-2xl animate-float-slow" size={224} glow={false} />
              </div>

              {/* Floating product chips */}
              <div class="absolute top-4 -left-4 sm:left-2 surface px-3 py-2 text-xs font-medium animate-float-slow" style="animation-delay:-3s">
                <span class="inline-flex items-center gap-1.5">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                  KodSpot Menu · Live
                </span>
              </div>
              <div class="absolute bottom-8 -right-4 sm:right-2 surface px-3 py-2 text-xs font-medium animate-float-slower" style="animation-delay:-7s">
                <span class="inline-flex items-center gap-1.5">
                  <span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span>
                  KodSpot Electrical · Production
                </span>
              </div>
              <div class="absolute top-1/2 -right-2 sm:right-6 surface px-3 py-2 text-xs font-medium animate-float-slow" style="animation-delay:-10s">
                <span class="inline-flex items-center gap-1.5">
                  <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
                  KodSpot Housekeeping · 24×7
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Scroll cue */}
      <div class="mt-16 hidden sm:flex items-center justify-center gap-2 text-[11px] uppercase tracking-[0.3em] muted" data-reveal data-reveal-delay="6">
        <span class="h-px w-8 bg-current opacity-40"></span>
        Scroll to explore
        <span class="h-px w-8 bg-current opacity-40"></span>
      </div>
    </div>
  </section>

  {/* ============ MARQUEE — industries we serve ============ */}
  <section class="relative py-10 sm:py-14 border-y border-ink-200/60 dark:border-ink-800/60 bg-white/40 dark:bg-ink-950/40 backdrop-blur-xs marquee-mask overflow-hidden">
    <div class="marquee-track font-display text-4xl sm:text-6xl tracking-tight text-ink-300 dark:text-ink-700">
      {[...marqueeWords, ...marqueeWords].map((w) => (
        <span class="inline-flex items-center gap-12">
          <span>{w}</span>
          <span class="text-brand-500 dark:text-brand-400">✦</span>
        </span>
      ))}
    </div>
  </section>

  {/* ============ STATS ============ */}
  <Stats />

  {/* ============ TRUSTED BY ============ */}
  <section class="container-page mt-24 sm:mt-32">
    <p class="eyebrow justify-center w-full text-center" data-reveal>
      <span class="h-px w-6 bg-current opacity-40"></span>
      Trusted by institutions in Belagavi
      <span class="h-px w-6 bg-current opacity-40"></span>
    </p>
    <ul class="mt-10 grid gap-5 sm:grid-cols-3" role="list">
      {CLIENT_LOGOS.map((c, i) => (
        <li
          data-reveal
          data-reveal-delay={i + 1}
          data-tilt="5"
          class="card-glow spotlight surface-solid p-7 flex flex-col items-center justify-center text-center min-h-[140px] transition-all"
        >
          <span class="font-display text-2xl sm:text-3xl tracking-tight">{c.short}</span>
          <span class="mt-2 text-xs muted leading-snug max-w-[28ch]">{c.name}</span>
        </li>
      ))}
    </ul>
    <p class="mt-7 text-center text-xs muted" data-reveal>
      KLE Society — one of South India’s largest education and healthcare groups.
    </p>
  </section>

  {/* ============ PRODUCTS — bento grid ============ */}
  <section class="container-page mt-28 sm:mt-36 relative">
    <div class="orb orb-1 h-[300px] w-[300px] -z-10 -top-12 right-0 opacity-30"></div>
    <SectionHeading
      eyebrow="Products"
      title="Three production platforms, one engineering foundation."
      lead="Each KodSpot product solves a specific operational problem for hospitals, hotels, and restaurants — built on the same multi-tenant core."
    />
    <div class="mt-14 grid gap-6 lg:grid-cols-3 lg:auto-rows-fr">
      {PRODUCTS.map((p, i) => <ProductCard product={p} delay={i + 1} />)}
    </div>
  </section>

  {/* ============ PILLARS ============ */}
  <section class="container-page mt-28 sm:mt-36 relative">
    <div class="orb orb-2 h-[280px] w-[280px] -z-10 top-1/3 -left-12 opacity-25"></div>
    <SectionHeading
      eyebrow="What makes KodSpot different"
      title="Engineering discipline, not feature count."
      lead="Every platform we ship inherits the same security, compliance, and cost-control posture from day one."
    />
    <div class="mt-14">
      <FeatureGrid features={pillars} />
    </div>
  </section>

  {/* ============ CTA ============ */}
  <CTASection />
</BaseLayout>
