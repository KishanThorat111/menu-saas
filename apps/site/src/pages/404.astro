---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" noindex>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 mesh-bg pointer-events-none"></div>
    <div class="orb orb-1 h-[420px] w-[420px] -top-20 -left-24 pointer-events-none"></div>
    <div class="orb orb-2 h-[480px] w-[480px] -bottom-32 -right-24 pointer-events-none"></div>

    <div class="container-page relative pt-32 sm:pt-40 pb-32 text-center">
      <p class="font-mono text-[11px] sm:text-xs tracking-[0.28em] text-brand-600 dark:text-brand-300 uppercase" data-reveal>
        Error · 404
      </p>
      <h1 class="font-display font-medium tracking-[-0.04em] leading-[0.92] text-[80px] sm:text-[140px] lg:text-[200px] mt-6 gradient-brand-text" data-reveal data-reveal-delay="1">
        404
      </h1>
      <h2 class="heading-3 mt-2 sm:mt-4" data-reveal data-reveal-delay="2">This page doesn't exist.</h2>
      <p class="lead mt-5 max-w-xl mx-auto" data-reveal data-reveal-delay="3">
        The link you followed may be broken, or the page may have moved. Try the homepage, or get in touch with us directly.
      </p>
      <div class="mt-10 flex justify-center gap-3 flex-wrap" data-reveal data-reveal-delay="4">
        <a href="/" class="btn-accent magnetic" data-magnetic="0.25">Back to homepage</a>
        <a href="/contact" class="btn-outline magnetic" data-magnetic="0.2">Contact us</a>
      </div>
    </div>
  </section>
</BaseLayout>
