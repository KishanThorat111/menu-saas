---
interface Props {
  class?: string;
  glow?: boolean;
  size?: number;
}
const { class: className = '', glow = true, size } = Astro.props;
const inlineSize = size ? `width:${size}px;height:${size}px;` : '';
---
<span class:list={["relative inline-flex items-center justify-center shrink-0", className]} style={inlineSize} aria-label="KodSpot logo" role="img">
  {glow && (
    <span
      aria-hidden="true"
      class="absolute inset-0 -z-10 rounded-[28%] bg-brand-400/45 blur-xl opacity-70 transition-opacity duration-500 group-hover:opacity-100"
    ></span>
  )}
  <img
    src="/kodspot-logo.png"
    alt=""
    width={size ?? 64}
    height={size ?? 64}
    decoding="async"
    loading="eager"
    fetchpriority="high"
    class="h-full w-full object-contain drop-shadow-[0_4px_14px_rgba(201,116,38,0.45)] select-none pointer-events-none"
  />
</span>
