---
import { PRODUCTS } from '../lib/site';

interface Props {
  product: typeof PRODUCTS[number];
  delay?: number;
}
const { product, delay = 0 } = Astro.props;

const iconMap: Record<string, string> = {
  menu: '<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h16"/>',
  sparkle: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3zm6 11l.8 2.2L21 17l-2.2.8L18 20l-.8-2.2L15 17l2.2-.8L18 14z"/>',
  bolt: '<path stroke-linecap="round" stroke-linejoin="round" d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/>'
};
---
<a
  href={`/products/${product.slug}`}
  data-reveal
  data-reveal-delay={delay}
  class="group relative block rounded-3xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900/60 p-6 sm:p-8 overflow-hidden transition-all hover:-translate-y-1 hover:shadow-lift focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
>
  <div class={`pointer-events-none absolute -top-24 -right-24 h-56 w-56 rounded-full bg-gradient-to-br ${product.color} opacity-10 blur-2xl transition-opacity duration-500 group-hover:opacity-20`}></div>

  <div class="relative flex items-center justify-between">
    <span class={`inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br ${product.color} text-white shadow-soft`}>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" set:html={iconMap[product.icon]}></svg>
    </span>
    <span class="chip">{product.status}</span>
  </div>

  <h3 class="mt-6 text-xl sm:text-2xl font-display font-semibold tracking-tight">{product.name}</h3>
  <p class="mt-2 text-sm text-ink-500 dark:text-ink-400">{product.audience}</p>
  <p class="mt-4 text-sm sm:text-base text-ink-700 dark:text-ink-300 leading-relaxed">{product.short}</p>

  <div class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-brand-600 dark:text-brand-300">
    Explore product
    <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
  </div>
</a>
