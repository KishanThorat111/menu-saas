---
import { PRODUCTS } from '../lib/site';

interface Props {
  product: typeof PRODUCTS[number];
  delay?: number;
}
const { product, delay = 0 } = Astro.props;

const iconMap: Record<string, string> = {
  menu: '<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h16"/>',
  sparkle: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3zm6 11l.8 2.2L21 17l-2.2.8L18 20l-.8-2.2L15 17l2.2-.8L18 14z"/>',
  bolt: '<path stroke-linecap="round" stroke-linejoin="round" d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/>'
};
---
<a
  href={`/products/${product.slug}`}
  data-reveal
  data-reveal-delay={delay}
  data-tilt="6"
  class="group card-glow spotlight relative flex flex-col rounded-3xl border border-ink-200/80 dark:border-ink-800/80 bg-white dark:bg-ink-900/60 p-7 sm:p-9 overflow-hidden transition-all hover:shadow-lift-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 h-full"
>
  {/* Spotlight blob */}
  <div class={`pointer-events-none absolute -top-32 -right-24 h-72 w-72 rounded-full bg-gradient-to-br ${product.color} opacity-[0.10] blur-3xl transition-opacity duration-500 group-hover:opacity-[0.20]`}></div>

  <div class="relative tilt-inner flex items-start justify-between gap-4">
    <span class={`inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br ${product.color} text-white shadow-ring-brand`}>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24" set:html={iconMap[product.icon]}></svg>
    </span>
    <div class="flex flex-col items-end gap-1.5">
      <span class="chip">{product.status}</span>
      <span class="text-[10px] font-mono uppercase tracking-[0.18em] muted">{product.domain}</span>
    </div>
  </div>

  <h3 class="relative tilt-inner mt-7 font-display tracking-tight text-2xl sm:text-3xl">{product.name}</h3>
  <p class="relative tilt-inner mt-2 text-sm muted">{product.audience}</p>
  <p class="relative tilt-inner mt-5 text-ink-700 dark:text-ink-300 leading-relaxed text-sm sm:text-base flex-1">{product.short}</p>

  <div class="relative tilt-inner mt-7 inline-flex items-center gap-1.5 text-sm font-medium text-brand-600 dark:text-brand-300">
    <span class="border-b border-current/40 group-hover:border-current transition-colors">Explore product</span>
    <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7"/></svg>
  </div>
</a>
