---
interface Feature { title: string; desc: string; icon?: string }
interface Props { features: Feature[]; columns?: 2 | 3 }
const { features, columns = 3 } = Astro.props;
const gridCols = columns === 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3';
---
<div class:list={['grid gap-5', gridCols]}>
  {features.map((f, i) => (
    <div
      class="card-glow spotlight surface-solid p-7 sm:p-8 transition-all hover:border-brand-300/70 dark:hover:border-brand-500/40"
      data-reveal
      data-reveal-delay={Math.min((i % 3) + 1, 4)}
      data-tilt="4"
    >
      <div class="flex items-center justify-between">
        <span class="font-mono text-[11px] tracking-[0.18em] muted uppercase">
          0{i + 1}
        </span>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-brand-400 to-brand-600 text-white shadow-ring-brand">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </span>
      </div>
      <h3 class="mt-7 text-xl font-display tracking-tight">{f.title}</h3>
      <p class="mt-3 text-sm text-ink-600 dark:text-ink-400 leading-relaxed">{f.desc}</p>
    </div>
  ))}
</div>
