---
import { STATS } from '../lib/site';
---
<section class="container-page mt-20 sm:mt-28">
  <div class="surface-solid grid grid-cols-2 lg:grid-cols-4 gap-px overflow-hidden bg-ink-200/70 dark:bg-ink-800/70">
    {STATS.map((stat, i) => (
      <div
        class="bg-white dark:bg-ink-900 p-6 sm:p-8 flex flex-col gap-2"
        data-reveal
        data-reveal-delay={Math.min(i + 1, 4)}
      >
        <span class="font-display text-3xl sm:text-4xl font-semibold tracking-tight gradient-text">
          {stat.value}
        </span>
        <span class="text-sm muted leading-snug">{stat.label}</span>
      </div>
    ))}
  </div>
</section>
